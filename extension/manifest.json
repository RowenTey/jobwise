{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "jobwise@rowentey.xyz",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "name": "JobWise",
  "version": "0.0.1",
  "description": "Track job applications across LinkedIn",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "scripts": [
      "dist/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "templates/popup.html"
  }
}