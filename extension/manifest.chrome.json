{
  "manifest_version": 3,
  "name": "JobWise",
  "version": "2.0",
  "description": "Track job applications on LinkedIn and auto-fill Easy Apply forms.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["dist/content.js"]
    }
  ],
  "action": {
    "default_popup": "templates/popup.html"
  }
}
