{
  "manifest_version": 3,
  "name": "JobWise",
  "version": "2.0",
  "description": "Track job applications across LinkedIn, Indeed, Greenhouse, and Lever.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://*.indeed.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*"
  ],
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "templates/popup.html"
  }
}